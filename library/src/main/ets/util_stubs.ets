/**
 * ArkTS Lodash — Stub Functions
 * Functions that return default/empty values.
 */

/**
 * Returns an empty array.
 */
export function stubArray(): Array<Object> {
  const result: Array<Object> = []
  return result
}

/**
 * Returns `false`.
 */
export function stubFalse(): boolean {
  return false
}

/**
 * Returns an empty object.
 */
export function stubObject(): Record<string, Object> {
  const result: Record<string, Object> = {}
  return result
}

/**
 * Returns an empty string.
 */
export function stubString(): string {
  return ''
}

/**
 * Returns `true`.
 */
export function stubTrue(): boolean {
  return true
}
